{

  "AppName": "Image Resizer",
  "AppVersion": "1.0.0",

  "InputFolder": "Input",
  "OutputFolder": "Output",

  "Resize": {
    "MaxLongSide": 1200,
    "AllowUpscale": false
  },

  "Output": {
    "Extension": ".jpg",
    "Quality": 90
  },

  "Extensions": [
    ".jpg",
    ".jpeg",
    ".png",
    ".bmp",
    ".heic"
  ]
}